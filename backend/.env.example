# Database
# Under docker-compose the DATABASE_URL is overridden in the compose file to
# use the db service hostname. This default is already set to the compose value
# so `docker-compose up` works without edits. Change the host to `localhost`
# and the credentials for standalone local dev.
DATABASE_URL=postgresql+asyncpg://carddroper:carddroper@db:5432/carddroper

# JWT — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-48-byte-random-url-safe-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=15
REFRESH_TOKEN_DAYS=7
JWT_ISSUER=carddroper
JWT_AUDIENCE=carddroper-api

# Cookies — set COOKIE_SECURE=false for local HTTP dev.
COOKIE_SECURE=false
COOKIE_DOMAIN=

# Frontend URL (used in verification / reset email links and Stripe returnURL)
FRONTEND_URL=http://localhost:3000
FRONTEND_BASE_URL=http://localhost:3000

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# Rate limits (slowapi strings)
REGISTER_RATE_LIMIT=3/minute
LOGIN_RATE_LIMIT=5/minute
REFRESH_RATE_LIMIT=10/minute
LOGOUT_RATE_LIMIT=10/minute
FORGOT_PASSWORD_RATE_LIMIT=3/hour
RESEND_VERIFICATION_RATE_LIMIT=3/hour
VERIFY_EMAIL_RATE_LIMIT=10/minute
CHANGE_EMAIL_RATE_LIMIT=3/hour
CONFIRM_EMAIL_CHANGE_RATE_LIMIT=10/minute

# Per-account login lockout
LOCKOUT_THRESHOLD=10
LOCKOUT_WINDOW_MINUTES=15
LOCKOUT_DURATION_MINUTES=15

# Password policy
PASSWORD_MIN_LENGTH=10
HIBP_ENABLED=true

# Token lifetimes
PASSWORD_RESET_EXPIRY_MINUTES=15
EMAIL_VERIFY_EXPIRY_HOURS=24
EMAIL_CHANGE_EXPIRY_HOURS=1

# Stripe (leave empty for local dev without billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# SendGrid — leave empty to log emails to stdout during local dev.
SENDGRID_API_KEY=
SENDGRID_SANDBOX=false
SENDGRID_TEMPLATE_VERIFY_EMAIL=
SENDGRID_TEMPLATE_RESET_PASSWORD=
SENDGRID_TEMPLATE_CHANGE_EMAIL=
SENDGRID_TEMPLATE_EMAIL_CHANGED=
SENDGRID_TEMPLATE_CREDITS_PURCHASED=
FROM_EMAIL=noreply@carddroper.com
FROM_NAME=Carddroper
