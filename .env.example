# Root .env.example — docker-compose substitution layer
#
# This file is read by Docker Compose ITSELF for ${VAR} substitutions inside
# docker-compose.yml — not by the backend or frontend containers directly.
# Only variables that docker-compose.yml references via ${VAR} belong here.
#
# For first-time setup:
#   cp .env.example .env
# Then fill in values below. The resulting .env is gitignored.
#
# Where other env vars live:
#   backend/.env.example  → backend/.env      — FastAPI runtime config
#                                                (pydantic-settings reads this
#                                                inside the backend container)
#   frontend/.env.example → frontend/.env.local — Next.js runtime config
#                                                 (only used if the frontend
#                                                 runs outside docker-compose;
#                                                 docker-compose bakes NEXT_PUBLIC_*
#                                                 via build args instead)
#
# See doc/operations/development.md §Env-var tiers for the full pattern.

# Stripe publishable key — consumed by docker-compose, passed as a
# --build-arg to the frontend Docker build, baked into the Next.js bundle
# as NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY so Stripe Elements can initialize
# client-side. Test mode: pk_test_... | Production: pk_live_...
# Leave empty to build a frontend that errors at /app/billing (acceptable
# when you're not exercising billing flows locally).
STRIPE_PUBLISHABLE_KEY=
